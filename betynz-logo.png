name: Deploy Betynz to Hostinger

on:
  workflow_dispatch:
  push:
    branches: [main]
    paths:
      - "site/**"
      - ".github/workflows/deploy-hostinger.yml"

permissions:
  contents: read

concurrency:
  group: betynz-hostinger-production
  cancel-in-progress: true

jobs:
  deploy:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Validate required Hostinger secrets
        shell: bash
        env:
          FTP_SERVER: ${{ secrets.HOSTINGER_FTP_SERVER }}
          FTP_USERNAME: ${{ secrets.HOSTINGER_FTP_USERNAME }}
          FTP_PASSWORD: ${{ secrets.HOSTINGER_FTP_PASSWORD }}
        run: |
          set -euo pipefail
          test -n "$FTP_SERVER" || { echo "Missing HOSTINGER_FTP_SERVER"; exit 1; }
          test -n "$FTP_USERNAME" || { echo "Missing HOSTINGER_FTP_USERNAME"; exit 1; }
          test -n "$FTP_PASSWORD" || { echo "Missing HOSTINGER_FTP_PASSWORD"; exit 1; }
          test -f site/index.html || { echo "site/index.html is missing"; exit 1; }

      - name: Install secure FTP client
        run: sudo apt-get update -qq && sudo apt-get install -y -qq lftp

      - name: Deploy site folder to Hostinger
        shell: bash
        env:
          FTP_SERVER: ${{ secrets.HOSTINGER_FTP_SERVER }}
          FTP_USERNAME: ${{ secrets.HOSTINGER_FTP_USERNAME }}
          FTP_PASSWORD: ${{ secrets.HOSTINGER_FTP_PASSWORD }}
          FTP_PORT: ${{ secrets.HOSTINGER_FTP_PORT }}
          REMOTE_DIR: ${{ secrets.HOSTINGER_REMOTE_DIR }}
        run: |
          set -euo pipefail
          FTP_PORT="${FTP_PORT:-21}"
          REMOTE_DIR="${REMOTE_DIR:-/public_html/}"
          lftp -c "
            set cmd:fail-exit true;
            set net:max-retries 2;
            set net:timeout 20;
            set ftp:ssl-force true;
            set ftp:ssl-protect-data true;
            set ssl:verify-certificate no;
            open -p ${FTP_PORT} -u ${FTP_USERNAME},${FTP_PASSWORD} ${FTP_SERVER};
            mkdir -p ${REMOTE_DIR};
            mirror --reverse --only-newer --parallel=4 --verbose \
              --exclude-glob .DS_Store \
              --exclude-glob Thumbs.db \
              site/ ${REMOTE_DIR};
            bye;
          "
